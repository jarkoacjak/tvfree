<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.tv_free" 
       name="TV Free" 
       version="1.0.0" 
       provider-name="Jarko">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="sk">Slovenské a České TV vysielanie zadarmo.</summary>
        <description lang="sk">Tento doplnok umožňuje sledovanie vybraných slovenských a českých televíznych staníc priamo v Kodi.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
